# Copy this file to .env and fill in real values.
# DO NOT commit .env to git.

# PostgreSQL connection string
# Railway: copy from the Railway dashboard → Variables → DATABASE_URL
# Render: copy from the Render dashboard → Environment → DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/attendwise_erp

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change_me_to_a_long_random_secret

# Optional overrides
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DEBUG=false

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://attendwise-app.web.app

# Seed account credentials (change before deploying to production)
SEED_ADMIN_EMAIL=admin@attendwise.local
SEED_ADMIN_PASSWORD=change_me_admin_123
SEED_FACULTY_EMAIL=faculty@attendwise.local
SEED_FACULTY_PASSWORD=change_me_faculty_123
